class Solution {
public:
    int minimumSize(vector<int>& nums, int maxOperations) {
           int low=1;
           int high=*max_element(nums.begin(),nums.end());

           while(low<high){
            int mid=low+(high-low)/2;

            long long operations=0;

            for(auto it:nums){
                operations+=(it-1)/mid;
            }

            if(operations>maxOperations){
                 low=mid+1;
            }else{
                high=mid;
            }
           }
           return low;
    }
};
